@{
    ViewData["Title"] = "Dashboard";
}

<!-- =============================================================
     PAGE HEADER
     ============================================================= -->
<div class="vc-page-header vc-fade-up">
    <div>
        <div class="vc-page-eyebrow">Overview</div>
        <h1 class="vc-page-title">Welcome back, Dev 👋</h1>
        <p class="vc-page-subtitle">Here's what your AI agents have been working on.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-controller="Analysis" asp-action="Index" class="btn btn-vc-primary">
            <i class="bi bi-plus-lg me-1"></i> New Analysis
        </a>
    </div>
</div>

<!-- =============================================================
     STAT CARDS
     ============================================================= -->
<div class="row g-4 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="vc-card vc-stat-card">
            <div class="d-flex align-items-start justify-content-between mb-3">
                <div class="vc-stat-icon"><i class="bi bi-bar-chart-line-fill"></i></div>
                <span class="vc-stat-trend up"><i class="bi bi-arrow-up-short"></i>12%</span>
            </div>
            <div class="vc-stat-value">MongoDB Count</div>
            <div class="vc-stat-label">Total Analyses</div>
        </div>
    </div>

    <div class="col-sm-6 col-xl-3">
        <div class="vc-card vc-stat-card">
            <div class="d-flex align-items-start justify-content-between mb-3">
                <div class="vc-stat-icon"><i class="bi bi-cpu-fill"></i></div>
                <span class="vc-stat-trend up"><i class="bi bi-arrow-up-short"></i>4</span>
            </div>
            <div class="vc-stat-value">4</div>
            <div class="vc-stat-label">Active AI Agents</div>
        </div>
    </div>

    <div class="col-sm-6 col-xl-3">
        <div class="vc-card vc-stat-card">
            <div class="d-flex align-items-start justify-content-between mb-3">
                <div class="vc-stat-icon"><i class="bi bi-code-slash"></i></div>
                <span class="vc-stat-trend up"><i class="bi bi-arrow-up-short"></i>2</span>
            </div>
            <div class="vc-stat-value">4</div>
            <div class="vc-stat-label">Supported Languages</div>
        </div>
    </div>

    <div class="col-sm-6 col-xl-3">
        <div class="vc-card vc-stat-card">
            <div class="d-flex align-items-start justify-content-between mb-3">
                <div class="vc-stat-icon"><i class="bi bi-database-fill-check"></i></div>
                <span class="vc-badge success"><span class="vc-status-dot online"></span>Connected</span>
            </div>
            <div class="vc-stat-value" style="font-size:1.25rem;">MongoDB Atlas</div>
            <div class="vc-stat-label">Database Status</div>
        </div>
    </div>
</div>

<!-- =============================================================
     QUICK ACTIONS
     ============================================================= -->
<div class="vc-card mb-4 vc-fade-up">
    <h5 class="mb-3"><i class="bi bi-lightning-charge-fill me-2 vc-gradient-text"></i>Quick Actions</h5>
    <div class="d-flex flex-wrap gap-3">
        <a asp-controller="Home" asp-action="Index" class="btn btn-vc-primary">
            <i class="bi bi-magic me-2"></i>New Analysis
        </a>
        <a asp-controller="Analysis" asp-action="Ana" class="btn btn-vc-outline">
            <i class="bi bi-clock-history me-2"></i>View History
        </a>
        <button type="button" class="btn btn-vc-danger-ghost" data-bs-toggle="modal" data-bs-target="#vcClearHistoryModal">
            <i class="bi bi-trash3 me-2"></i>Clear History
        </button>
    </div>
</div>

<div class="row g-4">
    <!-- =========================================================
         RECENT ACTIVITY TABLE
         ========================================================= -->
    <div class="col-xl-8">
        <div class="vc-card h-100 vc-fade-up">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <h5 class="mb-0"><i class="bi bi-activity me-2 vc-gradient-text"></i>Recent Activity</h5>
                <a asp-controller="Home" asp-action="History" class="vc-text-dim small">View all <i class="bi bi-arrow-right ms-1"></i></a>
            </div>

            <div class="vc-table-wrap">
                <div class="table-responsive">
                    <table class="table vc-table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Language</th>
                                <th>AI Agent</th>
                                <th>Status</th>
                                <th class="text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Jul 04, 2026 &middot; 10:12 AM</td>
                                <td><i class="bi bi-filetype-py me-1 vc-text-dim"></i>Python</td>
                                <td>Bug Detector</td>
                                <td><span class="vc-badge success"><i class="bi bi-check-circle-fill"></i>Completed</span></td>
                                <td class="text-end">
                                    <button class="btn-vc-icon" title="View result"><i class="bi bi-eye"></i></button>
                                </td>
                            </tr>
                            <tr>
                                <td>Jul 04, 2026 &middot; 09:47 AM</td>
                                <td><i class="bi bi-filetype-java me-1 vc-text-dim"></i>Java</td>
                                <td>Code Reviewer</td>
                                <td><span class="vc-badge success"><i class="bi bi-check-circle-fill"></i>Completed</span></td>
                                <td class="text-end">
                                    <button class="btn-vc-icon" title="View result"><i class="bi bi-eye"></i></button>
                                </td>
                            </tr>
                            <tr>
                                <td>Jul 03, 2026 &middot; 06:30 PM</td>
                                <td><i class="bi bi-filetype-js me-1 vc-text-dim"></i>JavaScript</td>
                                <td>Documentation Generator</td>
                                <td><span class="vc-badge warning"><i class="bi bi-hourglass-split"></i>Processing</span></td>
                                <td class="text-end">
                                    <button class="btn-vc-icon" title="View result"><i class="bi bi-eye"></i></button>
                                </td>
                            </tr>
                            <tr>
                                <td>Jul 03, 2026 &middot; 02:05 PM</td>
                                <td><i class="bi bi-filetype-cs me-1 vc-text-dim"></i>C#</td>
                                <td>Code Explainer</td>
                                <td><span class="vc-badge danger"><i class="bi bi-x-circle-fill"></i>Failed</span></td>
                                <td class="text-end">
                                    <button class="btn-vc-icon" title="Retry"><i class="bi bi-arrow-repeat"></i></button>
                                </td>
                            </tr>
                            <tr>
                                <td>Jul 02, 2026 &middot; 11:58 AM</td>
                                <td><i class="bi bi-filetype-cpp me-1 vc-text-dim"></i>C++</td>
                                <td>Bug Detector</td>
                                <td><span class="vc-badge success"><i class="bi bi-check-circle-fill"></i>Completed</span></td>
                                <td class="text-end">
                                    <button class="btn-vc-icon" title="View result"><i class="bi bi-eye"></i></button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- =========================================================
         AI AGENTS
         ========================================================= -->
    <div class="col-xl-4">
        <div class="vc-card h-100 vc-fade-up">
            <h5 class="mb-3"><i class="bi bi-robot me-2 vc-gradient-text"></i>AI Agents</h5>

            <div class="d-flex flex-column gap-3">
                <div class="vc-agent-card">
                    <div class="vc-agent-icon blue"><i class="bi bi-search-heart"></i></div>
                    <div class="flex-grow-1">
                        <div class="d-flex align-items-center justify-content-between">
                            <span class="fw-semibold">Code Reviewer</span>
                            <span class="vc-status-dot online"></span>
                        </div>
                        <div class="vc-text-faint small">Reviews style, structure &amp; best practices</div>
                    </div>
                </div>

                <div class="vc-agent-card">
                    <div class="vc-agent-icon purple"><i class="bi bi-bug-fill"></i></div>
                    <div class="flex-grow-1">
                        <div class="d-flex align-items-center justify-content-between">
                            <span class="fw-semibold">Bug Detector</span>
                            <span class="vc-status-dot online"></span>
                        </div>
                        <div class="vc-text-faint small">Finds logic errors &amp; edge cases</div>
                    </div>
                </div>

                <div class="vc-agent-card">
                    <div class="vc-agent-icon cyan"><i class="bi bi-chat-left-text-fill"></i></div>
                    <div class="flex-grow-1">
                        <div class="d-flex align-items-center justify-content-between">
                            <span class="fw-semibold">Code Explainer</span>
                            <span class="vc-status-dot online"></span>
                        </div>
                        <div class="vc-text-faint small">Breaks code down step by step</div>
                    </div>
                </div>

                <div class="vc-agent-card">
                    <div class="vc-agent-icon green"><i class="bi bi-file-earmark-richtext-fill"></i></div>
                    <div class="flex-grow-1">
                        <div class="d-flex align-items-center justify-content-between">
                            <span class="fw-semibold">Documentation Generator</span>
                            <span class="vc-status-dot busy"></span>
                        </div>
                        <div class="vc-text-faint small">Generates docstrings &amp; README content</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- =============================================================
     CLEAR HISTORY CONFIRMATION MODAL
     ============================================================= -->
<div class="modal fade" id="vcClearHistoryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content vc-glass" style="border-radius:1rem;">
            <div class="modal-header border-0">
                <h5 class="modal-title"><i class="bi bi-exclamation-triangle-fill text-warning me-2"></i>Clear all history?</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body vc-text-dim">
                This will permanently remove all analysis history. This action cannot be undone.
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-vc-outline" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger">Clear History</button>
            </div>
        </div>
    </div>
</div>
